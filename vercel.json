{
  "version": 2,
  "buildCommand": "pnpm run build",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null,
  "outputDirectory": "dist/public",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "includeFiles": "dist/**"
    }
  },
  "rewrites": [
    { "source": "/api/trpc/(.*)", "destination": "/api" },
    { "source": "/api/oauth/(.*)", "destination": "/api" },
    { "source": "/api/contact", "destination": "/api" },
    { "source": "/api/export/(.*)", "destination": "/api" },
    { "source": "/api/v1/(.*)", "destination": "/api" },
    { "source": "/api/health", "destination": "/api" },
    { "source": "/api/webhooks/(.*)", "destination": "/api" },
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
